BoxLayout:
    orientation: "vertical"
    padding: 10
    spacing: 10

    Button:
        text: "Запустить диагностику"
        size_hint_y: None
        height: "48dp"
        on_release: app.run_diagnostics()

    ScrollView:
        do_scroll_x: True
        do_scroll_y: True
        bar_width: "10dp"

        Label:
            id: output_box
            text: "Нажмите кнопку для запуска..."
            text_size: self.width, None
            size_hint_y: None
            height: self.texture_size[1]
            valign: "top"
            halign: "left"
            padding: "6dp", "6dp"