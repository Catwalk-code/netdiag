#:import dp kivy.metrics.dp
#:import Graph kivy_garden.graph.Graph

BoxLayout:
    orientation: "vertical"
    padding: dp(10)
    spacing: dp(10)

    BoxLayout:
        size_hint_y: None
        height: dp(48)
        spacing: dp(8)

        Button:
            text: "Старт мониторинга"
            on_release: app.start_monitoring()

        Button:
            text: "Стоп"
            on_release: app.stop_monitoring()

        Button:
            text: "Сохранить отчёт"
            on_release: app.save_report()

    GridLayout:
        id: target_indices
        size_hint_y: None
        height: dp(22)
        cols: 1
        spacing: dp(4)

    Graph:
        id: ping_graph
        size_hint_y: 0.58
        xlabel: "Цели"
        ylabel: "Ping (ms)"
        x_grid: True
        y_grid: True
        x_grid_label: False
        y_grid_label: True
        x_ticks_major: 2
        y_ticks_major: 10

    Label:
        id: ping_legend
        size_hint_y: None
        height: self.texture_size[1]
        text: "Ожидание данных ping..."
        halign: "left"
        valign: "middle"
        text_size: self.width, None

    ScrollView:
        do_scroll_x: False
        do_scroll_y: True
        bar_width: dp(10)

        Label:
            id: output_box
            text: ""
            text_size: self.width, None
            size_hint_y: None
            height: max(self.texture_size[1], dp(36))
            halign: "left"
            valign: "top"
            padding: dp(6), dp(6)
            color: 0, 0, 0, 1
            canvas.before:
                Color:
                    rgba: 1, 1, 1, 1
                Rectangle:
                    pos: self.pos
                    size: self.size
